# Supabase — get these from your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — SERVER ONLY. Never expose to the browser. (Settings -> API -> service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Comma-separated list of emails allowed to create/use admin accounts.
# These emails are also seeded into the `admins` table by the SQL migration if you set them there.
ADMIN_ALLOWLIST=you@example.com
