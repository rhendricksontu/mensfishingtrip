# Supabase — get these from your Supabase project: Settings -> API Keys
# Use the BASE project URL with NO /rest/v1/ path (supabase-js adds that itself).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Publishable key (browser-safe). Settings -> API Keys -> "Publishable key"
# Looks like: sb_publishable_...  (this replaced the old "anon" key)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Secret key — SERVER ONLY. Never expose to the browser.
# Settings -> API Keys -> "Secret keys" -> reveal/create. Looks like: sb_secret_...
# (this replaced the old "service_role" key)
SUPABASE_SECRET_KEY=sb_secret_xxx

# Comma-separated list of emails allowed to create/use admin accounts.
# These emails are also seeded into the `admins` table by the SQL migration if you set them there.
ADMIN_ALLOWLIST=you@example.com
